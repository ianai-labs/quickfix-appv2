# ============================================
# Quickfix App v2 — Environment Variables
# ============================================
# Salin file ini menjadi .env
#   cp .env.example .env
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database MySQL ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=quickfix_v2
MYSQL_USER=quickfix_user
MYSQL_PASSWORD=quickfix_pass
DB_HOST=mysql
DB_PORT=3306
DB_NAME=quickfix_v2
DB_USER=quickfix_user
DB_PASS=quickfix_pass

# --- JWT ---
JWT_SECRET=ganti-dengan-random-string-panjang-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-random-string-lain-untuk-refresh-token
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Session ---
SESSION_SECRET=ganti-dengan-random-string-untuk-session

# --- Device Tracking ---
DEVICE_SECRET=ganti-dengan-secret-untuk-hash-device-id

# --- Cloudinary (Cloud File Storage) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- SMTP Email (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Quickfix App <noreply@quickfix.local>
