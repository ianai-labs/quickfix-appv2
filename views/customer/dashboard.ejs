<div class="stats-grid" id="statsCards"></div>

<div class="card">
  <div class="card-header">
    <h2>Orders Saya</h2>
    <div style="display:flex;gap:8px">
      <select id="statusFilter" class="form-control" style="width:auto" onchange="loadOrders()">
        <option value="">Semua Status</option><option value="pending">Pending</option><option value="assigned">Assigned</option>
        <option value="on_the_way">On The Way</option><option value="in_progress">In Progress</option><option value="done">Selesai</option>
      </select>
      <a href="/customer/orders/new" class="btn btn-primary btn-sm">+ Order Baru</a>
    </div>
  </div>
  <div id="orderList"><div class="loading-center"><div class="spinner spinner-lg"></div></div></div>
</div>

<script src="/js/main.js"></script>
<script>
async function loadOrders() {
  const status = document.getElementById('statusFilter').value;
  const url = status ? `/api/orders?status=${status}` : '/api/orders';
  const res = await fetch(url); const data = await res.json();
  if (!data.success) return;
  const orders = data.data.orders;

  // Load payment statuses
  const txns = await Promise.all(orders.map(o => fetch(`/api/payment/status/${o.id}`).then(r => r.json()).catch(() => ({}))));

  if (!orders.length) {
    document.getElementById('statsCards').innerHTML = '';
    document.getElementById('orderList').innerHTML = '<div class="empty-state"><div class="empty-icon">📋</div><h3>Belum ada order</h3><p>Buat order perbaikan pertama Anda</p><a href="/customer/orders/new" class="btn btn-primary">+ Buat Order</a></div>';
    return;
  }

  const counts = {}; orders.forEach(o => counts[o.status] = (counts[o.status]||0)+1);
  document.getElementById('statsCards').innerHTML = [
    { label:'Total', value:orders.length, icon:'📋', color:'var(--info)' },
    { label:'Aktif', value:(counts.assigned||0)+(counts.on_the_way||0)+(counts.in_progress||0), icon:'🔧', color:'var(--primary)' },
    { label:'Selesai', value:counts.done||0, icon:'✅', color:'var(--success)' },
  ].map(s => `<div class="stat-card"><div class="stat-icon">${s.icon}</div><div class="stat-value" style="color:${s.color}">${s.value}</div><div class="stat-label">${s.label}</div></div>`).join('');

  document.getElementById('orderList').innerHTML = `
    <div class="table-wrap"><table class="table"><thead><tr><th>ID</th><th>Layanan</th><th>Teknisi</th><th>Status</th><th>Pembayaran</th><th>Tgl</th><th></th></tr></thead>
    <tbody>${orders.map((o,i) => {
      const txn = txns[i]?.data?.transaction;
      return `<tr>
        <td><strong>#${o.id}</strong></td><td>${o.layanan}</td>
        <td>${o.technician ? o.technician.nama : '<span style="color:var(--gray-300)">Menunggu</span>'}</td>
        <td>${statusBadge(o.status)}</td>
        <td>${txn ? statusBadge(txn.status) + (txn.amount ? ' '+formatIDR(txn.amount) : '') : '<span class="badge badge-pending">-</span>'}</td>
        <td>${formatDate(o.created_at)}</td>
        <td><a href="/customer/orders/${o.id}" class="btn btn-sm btn-outline">Detail</a></td>
      </tr>`;
    }).join('')}</tbody></table></div>`;
}

loadOrders();
</script>
