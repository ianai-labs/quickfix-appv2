<!DOCTYPE html>
<html lang="id">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Reset Password — Quickfix</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="login-bg">
  <div class="login-card">
    <h1>&#x1F527; Quickfix</h1>
    <p>Password Baru</p>
    <form id="resetForm">
      <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>">
      <div class="form-group pw-group">
        <label>Password Baru</label>
        <input type="password" name="password" class="form-control" required minlength="6" placeholder="min. 6 karakter">
        <button type="button" class="pw-toggle">&#x1F441;&#xFE0F;</button>
      </div>
      <div class="form-group pw-group">
        <label>Konfirmasi Password</label>
        <input type="password" name="password_confirm" class="form-control" required minlength="6" placeholder="ulangi password">
        <button type="button" class="pw-toggle">&#x1F441;&#xFE0F;</button>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%" id="submitBtn">Reset Password</button>
    </form>
    <div class="login-footer"><a href="/">← Kembali ke Login</a></div>
  </div>
</div>
<script src="/js/main.js"></script>
<script>
document.getElementById('resetForm').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = document.getElementById('submitBtn'); setLoading(btn, '...');
  const data = Object.fromEntries(new FormData(e.target));
  if (data.password !== data.password_confirm) { showToast('Password tidak cocok', 'error'); resetLoading(btn); return; }
  if (data.password.length < 6) { showToast('Password minimal 6 karakter', 'error'); resetLoading(btn); return; }
  try {
    const res = await fetch('/api/auth/reset-password', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    const result = await res.json();
    showToast(result.message, result.success ? 'success' : 'error');
    if (result.success) setTimeout(() => window.location.href = '/', 1000);
  } catch (_) { showToast('Gagal terhubung', 'error'); }
  resetLoading(btn);
});
setupPasswordToggles();
</script>
</body>
</html>
