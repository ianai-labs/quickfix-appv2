<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Quickfix — Layanan Perbaikan Rumah Profesional</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- HERO -->
<header class="landing-hero">
  <div class="landing-nav">
    <a href="/" class="landing-logo">🔧 Quickfix</a>
    <div>
      <a href="/register" class="btn btn-outline" style="color:#fff;border-color:rgba(255,255,255,0.3)">Daftar</a>
    </div>
  </div>
  <div class="landing-hero-content">
    <div class="landing-hero-text">
      <h1>Perbaikan Rumah,<br><span style="color:var(--primary)">Tanpa Ribet.</span></h1>
      <p>Cari teknisi AC, listrik, pipa, atap — dalam hitungan menit. Bayar aman dengan escrow. Puas baru lepas dana.</p>
      <div style="display:flex;gap:12px;flex-wrap:wrap">
        <a href="/register" class="btn btn-primary btn-lg">Mulai Sekarang</a>
        <a href="#loginSection" class="btn btn-outline btn-lg" style="color:#fff;border-color:rgba(255,255,255,0.3)">Sudah Punya Akun?</a>
      </div>
    </div>
    <div class="landing-hero-illustration">
      <div style="font-size:8rem;text-align:center">🔧</div>
    </div>
  </div>
</header>

<!-- FEATURES -->
<section class="landing-features">
  <h2>Kenapa Quickfix?</h2>
  <div class="landing-features-grid">
    <div class="landing-feature-card">
      <div class="landing-feature-icon">🔒</div>
      <h3>Pembayaran Aman</h3>
      <p>Escrow system: dana ditahan sampai pekerjaan selesai. Anda yang tentukan kapan dana dilepas.</p>
    </div>
    <div class="landing-feature-card">
      <div class="landing-feature-icon">⚡</div>
      <h3>Teknisi Cepat</h3>
      <p>Algoritma cerdas langsung menugaskan teknisi terbaik. Premium & rating tinggi diprioritaskan.</p>
    </div>
    <div class="landing-feature-card">
      <div class="landing-feature-icon">✅</div>
      <h3>Terpercaya</h3>
      <p>Verifikasi OTP setiap teknisi datang. Two-way review. Rating transparan. Kualitas terjamin.</p>
    </div>
  </div>
</section>

<!-- LOGIN SECTION -->
<section class="landing-login" id="loginSection">
  <div class="login-card" style="box-shadow:var(--shadow-lg)">
    <h1>🔧 Quickfix</h1>
    <p>Masuk ke akun Anda</p>

    <div class="role-tabs" id="roleTabs">
      <button class="role-tab active" data-role="customer">👤 Pencari Jasa</button>
      <button class="role-tab" data-role="technician">👨‍🔧 Penyedia Jasa</button>
      <button class="role-tab" data-role="admin">👑 Admin</button>
    </div>
    <p class="role-hint" id="roleHint">Untuk booking & memantau perbaikan</p>

    <form id="loginForm">
      <div class="form-group"><input type="text" name="login" class="form-control" required placeholder="Username atau Email" autofocus></div>
      <div class="form-group pw-group">
        <input type="password" name="password" class="form-control" required placeholder="Password">
        <button type="button" class="pw-toggle">👁️</button>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%" id="loginBtn">Masuk</button>
    </form>

    <div class="login-footer">
      <a href="/register">Buat akun baru</a> · <a href="/forgot-password">Lupa password?</a>
    </div>

    <div class="login-demo">
      <small>Demo — klik langsung masuk</small>
      <div class="demo-btns">
        <button class="demo-btn" onclick="quickLogin('budi','admin123','customer')">👤 Budi (Customer)</button>
        <button class="demo-btn" onclick="quickLogin('andi','admin123','technician')">👨‍🔧 Andi (Teknisi)</button>
        <button class="demo-btn" onclick="quickLogin('admin','admin123','admin')">👑 Admin</button>
      </div>
    </div>
  </div>
</section>

<footer style="text-align:center;padding:2rem;background:var(--dark);color:#888;font-size:0.85rem">
  © 2026 Quickfix App — Tugas Pemrograman Fullstack
</footer>

<!-- OTP Modal -->
<div class="otp-overlay" id="otpOverlay" style="display:none">
  <div class="otp-modal">
    <h2>🔐 Verifikasi Perangkat Baru</h2>
    <p style="color:var(--gray-500);font-size:0.85rem;margin-bottom:1rem">Device baru terdeteksi. Kode OTP dikirim ke email Anda.</p>
    <div class="otp-dummy" id="otpDummy" style="display:none">
      <div class="otp-dummy-label">🚧 Demo Mode</div>
      <div class="otp-dummy-code" id="otpDummyCode"></div>
    </div>
    <input type="text" id="otpInput" class="form-control" placeholder="6 digit OTP" maxlength="6" inputmode="numeric" style="text-align:center;font-size:1.2rem;letter-spacing:4px">
    <div style="display:flex;gap:8px;margin-top:1rem">
      <button class="btn btn-outline" style="flex:1" id="otpCancel">Batal</button>
      <button class="btn btn-primary" style="flex:1" id="otpSubmit">Verifikasi</button>
    </div>
    <div class="otp-error" id="otpError"></div>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
let currentTempToken = null, selectedRole = 'customer';

document.querySelectorAll('.role-tab').forEach(tab => tab.addEventListener('click', () => {
  document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active'); selectedRole = tab.dataset.role;
  document.getElementById('roleHint').textContent = selectedRole === 'customer' ? 'Untuk booking & memantau perbaikan' : selectedRole === 'technician' ? 'Untuk menerima & mengerjakan order' : 'Untuk mengelola platform';
}));

async function quickLogin(u,p,r) {
  document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`[data-role="${r}"]`).classList.add('active');
  selectedRole = r;
  document.querySelector('[name="login"]').value = u;
  document.querySelector('[name="password"]').value = p;
  document.getElementById('loginForm').dispatchEvent(new Event('submit'));
}

document.getElementById('loginForm').addEventListener('submit', async e => {
  e.preventDefault(); const btn = document.getElementById('loginBtn');
  setLoading(btn, 'Masuk...'); clearErrors();
  const data = Object.fromEntries(new FormData(e.target));
  if (!data.login || !data.password) { showToast('Isi username/email dan password', 'error'); resetLoading(btn); return; }

  try {
    const res = await fetch('/api/auth/login', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) });
    const result = await res.json();
    if (result.success && result.data.require_otp) {
      currentTempToken = result.data.temp_token;
      document.getElementById('otpInput').value = '';
      document.getElementById('otpError').style.display = 'none';
      if (result.data.dev_otp) { document.getElementById('otpDummy').style.display='block'; document.getElementById('otpDummyCode').textContent=result.data.dev_otp; }
      else document.getElementById('otpDummy').style.display='none';
      document.getElementById('otpOverlay').style.display='flex'; document.getElementById('otpInput').focus();
    } else if (result.success) {
      const ur = result.data.user.role;
      if (selectedRole !== 'admin' && selectedRole !== ur && !(selectedRole === 'technician' && ur === 'admin')) { showToast('Role tidak sesuai. Pilih tab yang benar.','error'); resetLoading(btn); return; }
      window.location.href = {admin:'/admin/dashboard',technician:'/technician/dashboard',customer:'/customer/dashboard'}[ur]||'/';
    } else showToast(result.message,'error');
  } catch(_) { showToast('Gagal terhubung ke server','error'); }
  resetLoading(btn);
});

document.getElementById('otpSubmit').addEventListener('click', async () => {
  const code = document.getElementById('otpInput').value.trim();
  if (code.length!==6) { document.getElementById('otpError').textContent='Masukkan 6 digit OTP'; document.getElementById('otpError').style.display='block'; return; }
  setLoading(document.getElementById('otpSubmit'),'...');
  try {
    const res = await fetch('/api/auth/verify-device', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({temp_token:currentTempToken,code}) });
    const result = await res.json();
    if (result.success) { document.getElementById('otpOverlay').style.display='none'; const r={admin:'/admin/dashboard',technician:'/technician/dashboard',customer:'/customer/dashboard'}; window.location.href=r[result.data.user.role]; }
    else { document.getElementById('otpError').textContent=result.message; document.getElementById('otpError').style.display='block'; }
  } catch(_) { document.getElementById('otpError').textContent='Gagal verifikasi'; document.getElementById('otpError').style.display='block'; }
  resetLoading(document.getElementById('otpSubmit'));
});

document.getElementById('otpInput').addEventListener('keydown', e => { if(e.key==='Enter') document.getElementById('otpSubmit').click(); });
document.getElementById('otpCancel').addEventListener('click', ()=>document.getElementById('otpOverlay').style.display='none');
document.getElementById('otpOverlay').addEventListener('click', e => { if(e.target===e.currentTarget) document.getElementById('otpOverlay').style.display='none'; });
function clearErrors(){ document.querySelectorAll('.form-error').forEach(el=>el.style.display='none'); }
setupPasswordToggles();
</script>
</body>
</html>
