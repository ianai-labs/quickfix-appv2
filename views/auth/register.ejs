<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar — Quickfix</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="login-bg">
  <div class="login-card">
    <h1>&#x1F527; Quickfix</h1>
    <p>Buat Akun Baru</p>

    <div class="role-tabs" id="roleTabs">
      <button class="role-tab active" data-role="customer">&#x1F464; Saya mencari jasa</button>
      <button class="role-tab" data-role="technician">&#x1F468;&#x200D;&#x1F527; Saya penyedia jasa</button>
    </div>
    <p class="role-hint" id="roleHint">Daftar sebagai <strong>Pencari Jasa</strong></p>

    <form id="registerForm">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" class="form-control" required minlength="3" placeholder="min. 3 karakter">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="form-control" required placeholder="nama@email.com">
      </div>
      <div class="form-group pw-group">
        <label>Password</label>
        <input type="password" name="password" class="form-control" required minlength="6" placeholder="min. 6 karakter">
        <button type="button" class="pw-toggle">&#x1F441;&#xFE0F;</button>
      </div>
      <div class="form-group pw-group">
        <label>Konfirmasi Password</label>
        <input type="password" name="password_confirm" class="form-control" required minlength="6" placeholder="ulangi password">
        <button type="button" class="pw-toggle">&#x1F441;&#xFE0F;</button>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%" id="regBtn">Daftar</button>
    </form>

    <div class="login-footer">
      Sudah punya akun? <a href="/">Login</a>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
let selectedRole = 'customer';

document.querySelectorAll('.role-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    selectedRole = tab.dataset.role;
    document.getElementById('roleHint').innerHTML = 'Daftar sebagai <strong>' + (selectedRole === 'customer' ? 'Pencari Jasa' : 'Penyedia Jasa') + '</strong>';
  });
});

document.getElementById('registerForm').addEventListener('submit', async e => {
  e.preventDefault();
  const btn = document.getElementById('regBtn');
  setLoading(btn, 'Mendaftar...');
  const data = Object.fromEntries(new FormData(e.target));
  data.role = selectedRole;

  if (data.password !== data.password_confirm) { showToast('Password tidak cocok', 'error'); resetLoading(btn); return; }
  if (data.username.length < 3) { showToast('Username minimal 3 karakter', 'error'); resetLoading(btn); return; }
  if (data.password.length < 6) { showToast('Password minimal 6 karakter', 'error'); resetLoading(btn); return; }

  try {
    const res = await fetch('/api/auth/register', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
    const result = await res.json();
    if (result.success) { showToast('Registrasi berhasil! Silakan login.', 'success'); setTimeout(() => window.location.href = '/', 800); }
    else showToast(result.message, 'error');
  } catch (_) { showToast('Gagal terhubung ke server', 'error'); }
  resetLoading(btn);
});

setupPasswordToggles();
</script>
</body>
</html>
