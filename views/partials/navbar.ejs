<nav class="navbar">
  <a href="/" class="navbar-brand">&#x1F527; <span>Quickfix</span></a>

  <ul class="navbar-nav">
    <% if (locals.user) { %>
      <% if (user.role === 'customer') { %>
        <li><a href="/customer/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">Orders Saya</a></li>
        <li><a href="/customer/orders/new" class="<%= active === 'new-order' ? 'active' : '' %>">+ Buat Order</a></li>
      <% } else if (user.role === 'technician') { %>
        <li><a href="/technician/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">Job Queue</a></li>
      <% } else if (user.role === 'admin') { %>
        <li><a href="/admin/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">Dashboard</a></li>
        <li><a href="/admin/orders" class="<%= active === 'orders' ? 'active' : '' %>">Orders</a></li>
        <li><a href="/admin/technicians" class="<%= active === 'technicians' ? 'active' : '' %>">Teknisi</a></li>
      <% } %>

      <li class="nav-user">
        <div class="nav-avatar <%= user.role %>"><%= (user.username || '?').charAt(0).toUpperCase() %></div>
        <span style="font-size:0.85rem;font-weight:600;color:var(--gray-700);"><%= user.username %></span>
        <a href="/api/auth/logout" class="logout-link" style="margin-left:8px;">Keluar</a>
      </li>
    <% } else { %>
      <li><a href="/">Login</a></li>
      <li><a href="/register">Daftar</a></li>
    <% } %>
  </ul>
</nav>
