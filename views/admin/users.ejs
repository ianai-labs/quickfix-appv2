<div class="card">
  <div class="card-header"><h3 style="margin-bottom:0.75rem">👤 Pencari Jasa (Customer)</h3></div>
  <div id="userList"><div class="loading-center"><div class="spinner spinner-lg"></div></div></div>
</div>

<script src="/js/main.js"></script>
<script>
async function loadUsers() {
  const res = await fetch('/api/admin/users');
  const data = await res.json();
  if (!data.success) return;
  const users = data.data.users;
  if (!users.length) { document.getElementById('userList').innerHTML = '<div class="empty-state"><div class="empty-icon">👤</div><h3>Belum ada customer</h3></div>'; return; }
  const roleIcons = { customer:'👤', technician:'👨‍🔧', admin:'👑' };
  const roleLabels = { customer:'Pencari Jasa', technician:'Penyedia Jasa', admin:'Admin' };
  const roleClasses = { customer:'badge-assigned', technician:'badge-otw', admin:'badge-done' };

  document.getElementById('userList').innerHTML = `
    <div class="table-wrap"><table class="table"><thead><tr><th>ID</th><th>Username</th><th>Email</th><th>Role</th><th>Detail</th><th>Status</th><th>Bergabung</th></tr></thead>
    <tbody>${users.map(u => `
      <tr>
        <td>#${u.id}</td><td><strong>${u.username}</strong></td><td>${u.email}</td>
        <td><span class="badge ${roleClasses[u.role]||'badge-pending'}">${roleIcons[u.role]||''} ${roleLabels[u.role]||u.role}</span></td>
        <td>${u.Customer?.no_hp ? `📱 ${u.Customer.no_hp}` : u.Customer?.alamat ? `📍 ${u.Customer.alamat.substring(0,30)}...` : '-'}</td>
        <td>${u.is_active ? '✅ Aktif' : '❌ Nonaktif'}</td>
        <td>${formatDate(u.created_at)}</td>
      </tr>
    `).join('')}</tbody></table></div>
    <p style="text-align:center;color:var(--gray-500);margin-top:8px">Total: ${users.length} customer</p>`;
}

loadUsers();
</script>
