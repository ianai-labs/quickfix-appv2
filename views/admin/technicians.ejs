<div class="card">
  <div class="card-header"><h2>Kelola Teknisi</h2></div>

  <div id="techList"><div class="loading-center"><div class="spinner spinner-lg"></div></div></div>
</div>

<script src="/js/main.js"></script>
<script>
async function loadTechnicians() {
  const res = await fetch('/api/technicians');
  const data = await res.json();
  const techs = data.data.technicians;
  if (!techs.length) { document.getElementById('techList').innerHTML = '<div class="empty-state"><div class="empty-icon">👨‍🔧</div><h3>Belum ada teknisi</h3></div>'; return; }

  document.getElementById('techList').innerHTML = `
    <table class="table">
      <thead><tr><th>Nama</th><th>Spesialisasi</th><th>Rating</th><th>Premium</th><th>Status</th><th>Jobs</th><th>Aksi</th></tr></thead>
      <tbody>${techs.map(t => `
        <tr>
          <td>${t.nama}</td>
          <td>${t.spesialisasi}</td>
          <td>&#x2B50; ${t.rating}</td>
          <td>${t.is_premium ? '<span class="badge badge-premium">🔥 Premium</span>' : '<span class="badge badge-pending">Regular</span>'}</td>
          <td>${t.status === 'online' ? '🟢 Online' : t.status === 'offline' ? '🔴 Offline' : '🟡 Busy'}</td>
          <td>${t.total_jobs}</td>
          <td class="actions">
            <button class="btn btn-sm ${t.is_premium ? 'btn-danger' : 'btn-success'}" onclick="togglePremium(${t.id}, ${t.is_premium})">
              ${t.is_premium ? 'Lepas Premium' : 'Set Premium'}
            </button>
          </td>
        </tr>
      `).join('')}</tbody>
    </table>
  `;
}

async function togglePremium(id, current) {
  const res = await api(`/api/technicians/${id}`, {
    method: 'PUT',
    body: JSON.stringify({ is_premium: !current }),
  });
  const result = await res.json();
  if (result.success) { showToast('Status premium diperbarui!', 'success'); loadTechnicians(); }
  else showToast(result.message, 'error');
}

loadTechnicians();
</script>
