<div class="card">
  <div class="card-header"><h2>Harga Layanan</h2></div>
  <p style="color:var(--gray-500);font-size:0.85rem;margin-bottom:1rem">Atur harga dasar dan persentase komisi platform per layanan.</p>
  <div id="pricingList"><div class="loading-center"><div class="spinner spinner-lg"></div></div></div>
</div>

<script src="/js/main.js"></script>
<script>
async function loadPricing() {
  const res = await fetch('/api/admin/pricing');
  const data = await res.json();
  const pricing = data.data.pricing;

  document.getElementById('pricingList').innerHTML = `
    <div class="table-wrap"><table class="table"><thead><tr><th>Layanan</th><th>Harga Dasar</th><th>Komisi %</th><th>Komisi Rp</th><th>Diterima Teknisi</th><th></th></tr></thead>
    <tbody>${pricing.map(p => {
      const commRp = Math.round(Number(p.base_price) * Number(p.commission_rate));
      return `<tr>
        <td><strong>${p.service_name}</strong></td>
        <td><input type="number" id="price_${p.id}" value="${Number(p.base_price)}" class="form-control" style="width:140px"></td>
        <td><input type="number" id="rate_${p.id}" value="${Math.round(Number(p.commission_rate)*100)}" min="0" max="50" class="form-control" style="width:80px"> %</td>
        <td style="color:var(--gray-500)" id="comm_${p.id}">${formatIDR(commRp)}</td>
        <td style="color:var(--success);font-weight:600" id="net_${p.id}">${formatIDR(Number(p.base_price)-commRp)}</td>
        <td><button class="btn btn-sm btn-primary" onclick="savePricing(${p.id})">Simpan</button></td>
      </tr>`;
    }).join('')}</tbody></table></div>`;
}

async function savePricing(id) {
  const price = document.getElementById(`price_${id}`).value;
  const rate = document.getElementById(`rate_${id}`).value;
  const res = await api(`/api/admin/pricing/${id}`, {
    method: 'PUT', body: JSON.stringify({ base_price: parseFloat(price), commission_rate: parseFloat(rate) / 100 })
  });
  const data = await res.json();
  if (data.success) { showToast('Harga diperbarui!', 'success'); loadPricing(); }
  else showToast(data.message, 'error');
}

loadPricing();
</script>
