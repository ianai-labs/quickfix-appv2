<div class="card">
  <div class="card-header"><h2>Semua Orders</h2></div>
  <div class="toolbar">
    <select id="statusFilter" class="form-control" style="width:auto" onchange="loadOrders()">
      <option value="">Semua Status</option>
      <option value="pending">Pending</option><option value="assigned">Assigned</option>
      <option value="on_the_way">On The Way</option><option value="in_progress">In Progress</option>
      <option value="done">Selesai</option><option value="cancelled">Batal</option>
    </select>
  </div>
  <div id="orderList"><div class="loading-center"><div class="spinner spinner-lg"></div></div></div>
</div>

<script src="/js/main.js"></script>
<script>
async function loadOrders(page = 1) {
  const status = document.getElementById('statusFilter').value;
  const params = new URLSearchParams({ page, limit: 15 }); if (status) params.set('status', status);
  const url = `/api/orders?${params}`;
  const res = await fetch(url); const data = await res.json();
  if (!data.success) return;
  const orders = data.data.orders;
  if (!orders.length) { document.getElementById('orderList').innerHTML = '<div class="empty-state"><div class="empty-icon">📋</div><h3>Belum ada order</h3></div>'; return; }

  // Load payment statuses
  const txnPromises = orders.map(o => fetch(`/api/payment/status/${o.id}`).then(r => r.json()).catch(() => ({})));
  const txns = await Promise.all(txnPromises);

  document.getElementById('orderList').innerHTML = `
    <div class="table-wrap"><table class="table"><thead><tr><th>ID</th><th>Layanan</th><th>Customer</th><th>Teknisi</th><th>Status</th><th>Pembayaran</th><th>Total</th><th>Tgl</th><th>Aksi</th></tr></thead>
    <tbody>${orders.map((o,i) => {
      const txn = txns[i]?.data?.transaction;
      const txnStatus = txn?.status || 'unpaid';
      const paid = txnStatus === 'paid';
      const released = txnStatus === 'released';
      return `<tr>
        <td><strong>#${o.id}</strong></td><td>${o.layanan}</td><td>${o.customer?.nama||'-'}</td>
        <td>${o.technician?.nama||'-'}</td><td>${statusBadge(o.status)}</td>
        <td>${statusBadge(txnStatus)}</td>
        <td>${txn ? formatIDR(txn.amount) : '-'}</td>
        <td>${formatDate(o.created_at)}</td>
        <td style="display:flex;gap:4px;flex-wrap:wrap">
          ${paid && !released ? `<button class="btn btn-sm btn-success" onclick="releasePayment(${o.id})">💸 Lepas Dana</button>` : ''}
          ${o.status === 'done' && txn ? `<span style="font-size:0.75rem;color:var(--gray-500)">Komisi: ${formatIDR(txn.commission)}</span>` : ''}
        </td>
      </tr>`;
    }).join('')}</tbody></table></div>
    ${renderPagination(data.data.pagination, 'loadOrders')}
    <p style="text-align:center;color:var(--gray-500);margin-top:8px">Total: ${data.data.pagination.total_items} orders</p>`;
}

async function releasePayment(orderId) {
  if (!(await confirmAction('Lepaskan dana ke teknisi?'))) return;
  const res = await api(`/api/payment/release/${orderId}`, { method: 'POST' });
  const data = await res.json();
  if (data.success) { showToast('Dana dilepas ke teknisi!', 'success'); loadOrders(); }
  else showToast(data.message, 'error');
}

loadOrders();
</script>
